{
  "name": "blockchain-voting-platform",
  "version": "0.1.0",
  "description": "Smart Multi-Format Electronic Voting Platform Secured by Blockchain Technology",
  "author": "Mircea",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
